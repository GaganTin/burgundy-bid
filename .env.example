# Optional: set the API base URL for the frontend to use (Vite env)
VITE_API_BASE_URL=http://localhost:3001
PORT=3001

# Google OAuth (from Google Cloud Console → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
# Dev: http://localhost:3001/auth/google/callback
# Prod: https://api.burgundybid.com/auth/google/callback
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback

# Frontend URL (used by OAuth callback redirect)
# Dev: http://localhost:5173
# Prod: https://burgundybid.com
FRONTEND_URL=http://localhost:5173
